# ===========================================
# TRAINERA - ENVIRONMENT VARIABLES
# ===========================================
# Copiar este archivo a .env.local y completar valores
# .env.local NO debe commitearse al repo
# ===========================================

# -------------------------------------------------------
# DATABASE
# -------------------------------------------------------
# Desarrollo local: Usar Docker PostgreSQL
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/trainera"
# 
# Vercel: Usar Vercel Postgres (ver dashboard de Vercel)
# O configurar una base externa (Railway, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# -------------------------------------------------------
# ADMIN AUTH
# -------------------------------------------------------
# Contraseña para acceder al panel de admin
ADMIN_PASSWORD="your-secure-password-here"

# Secret para la sesión (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SESSION_SECRET="64-char-hex-random-string"

# -------------------------------------------------------
# EMAIL (Resend)
# -------------------------------------------------------
# Obtener API key en https://resend.com
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="Trainera <noreply@yourdomain.com>"
EMAIL_DUENO="contact@yourdomain.com"

# -------------------------------------------------------
# CRON JOB SECURITY
# -------------------------------------------------------
# Secret para proteger el endpoint de cron jobs
CRON_SECRET="your-random-secret-here"

# -------------------------------------------------------
# APP URL
# -------------------------------------------------------
# Desarrollo: http://localhost:3000
# Producción: URL de tu dominio o Vercel (ej: https://trainera.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
